# MongoDB Atlas connection string
NUXT_ENV_MONGODB_URI=

# Square — server-side access token (runtimeConfig.squareAccessToken)
NUXT_SQUARE_ACCESS_TOKEN=

# Square — location ID (runtimeConfig.public.squareLocationId)
NUXT_PUBLIC_SQUARE_LOCATION_ID=

# Square — webhook signature key (runtimeConfig.squareWebhookSignatureKey)
NUXT_SQUARE_WEBHOOK_SIGNATURE_KEY=

# Square — environment: 'sandbox' or 'production' (runtimeConfig.squareEnvironment)
NUXT_SQUARE_ENVIRONMENT=sandbox

# Site domain for Square return URLs (runtimeConfig.domain)
# e.g. https://galvestondistilling.com or http://localhost:3001
NUXT_DOMAIN=

# Session encryption secret — 32+ random characters (runtimeConfig.sessionSecret)
NUXT_SESSION_SECRET=

# WebSocket URL for equipment controls (runtimeConfig.public.wsUrl)
NUXT_PUBLIC_WS_URL=

# Cloudinary (runtimeConfig.cloudinaryCloudName, etc.)
NUXT_CLOUDINARY_CLOUD_NAME=
NUXT_CLOUDINARY_API_KEY=
NUXT_CLOUDINARY_API_SECRET=
