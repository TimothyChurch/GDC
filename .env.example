# MongoDB Atlas connection string
NUXT_ENV_MONGODB_URI=

# Stripe — server-side secret key (runtimeConfig.stripe.key)
NUXT_STRIPE_KEY=

# Stripe — client-side publishable key (runtimeConfig.public.stripe.key)
NUXT_PUBLIC_STRIPE_KEY=

# Stripe price ID for checkout sessions (runtimeConfig.stripePriceId)
NUXT_STRIPE_PRICE_ID=

# Stripe webhook signing secret (runtimeConfig.stripeWebhookSecret)
NUXT_STRIPE_WEBHOOK_SECRET=

# Site domain for Stripe return URLs (runtimeConfig.domain)
# e.g. https://galvestondistilling.com or http://localhost:3001
NUXT_DOMAIN=

# Session encryption secret — 32+ random characters (runtimeConfig.sessionSecret)
NUXT_SESSION_SECRET=

# WebSocket URL for equipment controls (runtimeConfig.public.wsUrl)
NUXT_PUBLIC_WS_URL=

# Cloudinary (runtimeConfig.cloudinaryCloudName, etc.)
NUXT_CLOUDINARY_CLOUD_NAME=
NUXT_CLOUDINARY_API_KEY=
NUXT_CLOUDINARY_API_SECRET=
